NODE_ENV=production
PORT=3900
BHVR_API_BASE_URL=http://127.0.0.1:3900
REPORTER_DISABLED=1

# Browser defaults
BROWSER_CHANNEL=msedge
BROWSER_HEADLESS=false

# Runtime paths (resolved by launcher)
LIBSQL_URL=
CLIENT_DIST_DIR=
AUTOMATION_CLI_PATH=
NODE_RUNTIME_PATH=
AUTOMATION_STATE_DIR=

# In-memory run buffers
MAX_IN_MEMORY_RUNS=200
MAX_RUN_LOG_LINES=2000
COMPLETED_RUN_TTL_MS=1800000
